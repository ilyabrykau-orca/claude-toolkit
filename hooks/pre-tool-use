#!/usr/bin/env bash
# PreToolUse hook: block native Read/Edit/Write/Grep/Glob on code files.
# Route to Codanna/Serena MCP tools instead.
#
# PERFORMANCE: Single jaq/jq call (~5ms) + bash case matching.
# Prefers jaq (Rust) over jq, fails open if neither is available.
#
# Exit 2 = block. Exit 0 = allow. Fail-open on errors.

JQ=$(command -v jaq 2>/dev/null || command -v jq 2>/dev/null) || exit 0

input=$(</dev/stdin) 2>/dev/null || exit 0

# Single JSON extraction — tool_name + file_path (with fallback chain)
parsed=$(printf '%s' "$input" | "$JQ" -r \
  '[.tool_name // "", (.tool_input.file_path // .tool_input.pattern // .tool_input.path // "")] | @tsv' \
  2>/dev/null) || exit 0
IFS=$'\t' read -r tool_name file_path <<< "$parsed"

# Block Grep/Glob unconditionally
case "$tool_name" in
  Grep)
    echo "BLOCKED: Native Grep. Use mcp__codanna__semantic_search_with_context or mcp__serena__search_for_pattern." >&2
    exit 2 ;;
  Glob)
    echo "BLOCKED: Native Glob. Use mcp__codanna__search_symbols or mcp__serena__find_file." >&2
    exit 2 ;;
  Read|Edit|Write) ;;
  *) exit 0 ;;
esac

[[ -z "$file_path" ]] && exit 0

# Block on code file extensions
case "$file_path" in
  *.py|*.go|*.ts|*.tsx|*.js|*.jsx|*.rs|*.cpp|*.c|*.h|*.hpp|*.rb|*.java|*.kt|*.php|*.scala|*.swift|*.sh|*.bash)
    case "$tool_name" in
      Read)
        echo "BLOCKED: Native Read on '$file_path'. Use mcp__serena__find_symbol(include_body=True) or mcp__serena__read_file." >&2
        exit 2 ;;
      Edit|Write)
        echo "BLOCKED: Native $tool_name on '$file_path'. Use mcp__serena__replace_symbol_body or mcp__serena__replace_content." >&2
        exit 2 ;;
    esac ;;
esac

exit 0
